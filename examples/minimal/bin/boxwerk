#!/usr/bin/env ruby
# frozen_string_literal: true

# Load boxwerk directly from source (no Bundler required).
# Use exec to ensure exe/boxwerk runs as the top-level script,
# which is required for Ruby::Box.root.eval to work correctly.
boxwerk_exe = File.expand_path('../../../exe/boxwerk', __dir__)
boxwerk_lib = File.expand_path('../../../lib', __dir__)
exec(RbConfig.ruby, '-I', boxwerk_lib, boxwerk_exe, *ARGV)
